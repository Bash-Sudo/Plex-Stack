# User/Group IDs (use 1000 on Windows Docker Desktop)
PUID=1000
PGID=1000
TZ=America/Edmonton

# Paths
# Windows example: C:/Users/username/AppData/Local/PlexStack
BASE_PATH=

# Windows example: C:/Users/username/Videos
# Must contain subfolders: media/movies  media/tv  downloads/movies  downloads/tv
MEDIA_SHARE=

# Plex — get claim token at https://www.plex.tv/claim (expires in 4 minutes)
PLEX_CLAIM=claim-xxxx-xxxx
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=

# VPN (qBittorrent)
VPN_USER=
VPN_PASS=
VPN_PROV=pia
VPN_CLIENT=wireguard
LAN_NETWORK=192.168.1.0/24

# Network & API Keys (fill in after first run)
SERVER_IP=192.168.1.100
SONARR_KEY=
RADARR_KEY=

# VPN for qBittorrent
VPN_ENABLED=yes
VPN_REGION=CA Montreal   # Server region for gluetun (see gluetun docs for your provider)

# Hardware Transcoding
# none  — software transcoding (CPU), works everywhere
# nvidia — NVIDIA GPU via NVENC/NVDEC
#          Windows: update NVIDIA drivers + use Docker Desktop WSL2 backend (no extra setup)
#          Linux:   install nvidia-container-toolkit
# When set to nvidia, use: docker compose -f docker-compose.yml -f docker-compose.nvidia.yml up -d
GPU_PROVIDER=none
